addToCartAjax=()=>{var o=document.querySelector('form[action$="/cart/add"]'),o=new FormData(o);fetch(window.Shopify.routes.root+"cart/add.js",{method:"POST",body:o}).then(o=>o.json()).catch(o=>{console.error("Error:",o)})},document.querySelector('form.shopify-product-form input[type="submit"]').addEventListener("click",o=>{o.preventDefault(),addToCartAjax();o=document.querySelector("dialog");o.showModal()&&setTimeout(o.close(),3e3)});