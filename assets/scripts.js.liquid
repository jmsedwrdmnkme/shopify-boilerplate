addToCartAjax=()=>{var e=document.querySelector('form[action$="/cart/add"]'),e=new FormData(e);fetch(window.Shopify.routes.root+"cart/add.js",{method:"POST",body:e}).then(e=>e.json()).catch(e=>{console.error("Error:",e)})},document.querySelector('form.shopify-product-form input[type="submit"]').addEventListener("click",e=>{e.preventDefault(),addToCartAjax();e=document.querySelector("dialog");e.open(),setTimeout(e.close(),3e3)});