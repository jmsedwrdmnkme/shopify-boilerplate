:root{--base__size:1rem;--font__size:var(--base__size);--max__width:960px}*{margin:0}body{line-height:1.5;-webkit-font-smoothing:antialiased}canvas,img,picture,svg,video{display:block;max-width:100%}button,input,select,textarea{font:inherit}h1,h2,h3,h4,h5,h6,p{overflow-wrap:break-word}#__next,#root{isolation:isolate}[class*=container]{margin-left:auto;margin-right:auto;max-width:var(--max__width);padding:0 var(--base__size)}.flex{display:flex;flex-wrap:wrap;margin:calc(var(--base__size)*-1);--flex__basis:auto;flex:var(--flex) 0 var(--flex__basis);padding:var(--base__size)}&[class*="--33"]{--flex__basis:calc(100% / 3)}&[class*="--50"]{--flex__basis:calc(100% / 2)}&[class*="--66"]{--flex__basis:calc(calc(100% / 3) * 2)}&[class*="--75"]{--flex__basis:calc(calc(100% / 4) * 3)}&[class*="--"]{--flex:0}@media(min-width:992px){.nav__container{align-items:center;display:flex}}.nav__logo{font-size:calc(var(--font__size)*1.7)}@media(min-width:992px){.nav__logo{margin-right:auto}}