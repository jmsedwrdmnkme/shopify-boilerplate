/*
  Josh's Custom CSS Reset
  https://www.joshwcomeau.com/css/custom-css-reset/
  Last updated - April 3rd, 2024
*/

*, *::before, *::after {
  box-sizing: border-box;
}

* {
  margin: 0;
}

body {
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

img, picture, video, canvas, svg {
  display: block;
  max-width: 100%;
}

input, button, textarea, select {
  font: inherit;
}

p, h1, h2, h3, h4, h5, h6 {
  overflow-wrap: break-word;
}

#root, #__next {
  isolation: isolate;
}


/*
  Containers
*/

[class*=container] {
  --container__width--max: 60rem;
  --container__padding--x: 1rem;

  margin-left: auto;
  margin-right: auto;
  max-width: var(--container__width--max);
  padding-left: var(--container__padding--x);
  padding-right: var(--container__padding--x);
}


/*
  Skip to content
*/

.skip {
  &:not(:focus):not(:focus-within) {
    overflow: hidden;
    position: absolute;
    width: 1px;
  }
}


/*
  Nav
*/

.nav__label {
  display: inline-block;
  width: 1.5em;
  height: 1.5em;
  vertical-align: middle;
  background-image: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'><path stroke='#000000' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/></svg>");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 100%;
}

.nav__toggle {
  &:not(:checked) {
    ~  div {
      display: none;
    }

    ~ label {
      transform: rotate(90deg);
    }
  }
}


/*
  Helpers
*/

.hidden {
  display: none;
}
