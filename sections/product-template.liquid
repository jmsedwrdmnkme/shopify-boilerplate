<h1 class="product--title">{{ product.title }}</h1>
<p class="product--price">{{ product.price | money }}</p>

{% form 'product', product %}
  <input type="number" name="quantity" min="1" value="1">
  <select name="id"{% if product.has_only_default_variant %} class="hidden"{% endif %}>
    {% for variant in product.variants %}
      {% if variant.available == true %}
          <option value="{{ variant.id }}" data-price="{{ variant.price | money }}">{{ variant.title }}</option>
        {% else %}
          <option disabled="disabled">{{ variant.title }} (sold out)</option>
      {% endif %}
    {% endfor %}
  </select>
  <input type="submit" value="Add to cart">
  <dialog>
    <p><span class="dialog--quantity"></span> x <span class="dialog--title"></span> added to <a href="/cart">cart</a></p>
  </dialog>
{% endform %}

{%- for image in product.images -%}
  {%- capture variantTitle -%}
    {%- for variant in image.variants -%}
      {%- if image.attached_to_variant? -%}
        {{ variant.title }}
      {% endif %}
    {%- endfor -%}
  {%- endcapture -%}

  <picture class="product--image{% if variantTitle.size > 1 %} {{ variantTitle | downcase | strip }}{% endif %}{% if forloop.first %} active{% endif %}">
    <source media="(max-width: 375.98px)" srcset="{{ image.src | img_url: '343x343' }}" />
    <source media="(min-width: 376px) and (max-width: 575.98px)" srcset="{{ image.src | img_url: '543x543' }}" />
    <source media="(min-width: 576px) and (max-width: 768.98px)" srcset="{{ image.src | img_url: '736x736' }}" />
    <source media="(min-width: 769px)" srcset="{{ image.src | img_url: '928x928' }}" />
    <img
        src="{{ image.src | img_url: '928x928' }}"
        height="928" width="928"
        alt="{{ image.alt | escape }}{% if variantTitle.size > 1 %} {{ variantTitle | strip }}{% endif %}"
        {% unless forloop.first %}loading="lazy"{% endunless %}
    >
  </picture>
{%- endfor -%}

<p>{{ product.description }}</p>

{% schema %}
  {
    "name": "Product template",
    "tag": "section",
    "class": "product-template",
    "limit": 1,
    "settings": [],
    "presets": [
      {
        "name": "Product template"
      }
    ],
    "enabled_on": {
      "templates": ["product"]
    }
  }
{% endschema %}

{% stylesheet %}
  .product--image {
    &:not(.active) {
      display: none;
    }
  }

  form[action$="/cart/add"] {
    & dialog {
      border: unset;
      left: 50%;
      padding: var(--base__size);
      position: fixed;
      transform: translate(-50%, -50%);
      top: 50%;
    }
  }
{% endstylesheet %}

{% javascript %}
  const addToCartForm = document.querySelector('form[action$="/cart/add"]');
  const addToCartBtn = addToCartForm.querySelector('input[type="submit"]');

  addToCartAjax = () => {
    const formData = new FormData(addToCartForm);

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      body: formData
    })
    .then(response => {
      return response.json();
    })
    .catch((error) => {
      console.error('Error:', error);
    });
  };


  const addToCartSelect = addToCartForm.querySelector('select');
  const productTitle = document.querySelector('.product--title');
  const productPrice = document.querySelector('.product--price');
  const productPictures = document.querySelectorAll('.product--image');
  const productVariantTitle = addToCartSelect.options[addToCartSelect.selectedIndex].innerHTML;

  productImageUpdate = () => {
    forEach.productPictures((picture) => {
      (picture.classList.contains(productVariantTitle.toLowerCase())) ? picture.classList.add('active') : picture.classList.remove('active');
    });
  }

  productPriceUpdate = () => {
    const price = addToCartSelect.options[addToCartSelect.selectedIndex].getAttribute('data-price');

    productPrice.innerHTML = price;
  }

  document.addEventListener('DOMContentLoaded', () => productPriceUpdate());
  addToCartSelect.addEventListener('change', () => {
    productImageUpdate();
    productPriceUpdate();
  });


  const addToCartDialog = addToCartForm.querySelector('dialog');
  const dialogTitle = document.querySelector('.dialog--title');
  const dialogQuantity = document.querySelector('.dialog--quantity');

  addToCartBtn.addEventListener('click', (event) => {
    event.preventDefault();
    addToCartAjax();

    const title = `${productTitle.innerHTML} ${productVariantTitle}`;
    const quantity = addToCartForm.querySelector('input[name="quantity"]').value;

    dialogTitle.innerHTML = title;
    dialogQuantity.innerHTML = quantity;

    addToCartDialog.showModal();
    setTimeout(() =>  {
      addToCartDialog.close()
    }, 4000);
  });
{% endjavascript %}
